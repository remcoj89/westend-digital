---

const {
        buttonStyle = "btn-primary",
        buttonType = "button"
      } = Astro.props
---

<button type={buttonType} class={`btn ${buttonStyle}`}>
  <slot />
</button>


<style is:global>
  .btn {
    border: none;
    border-radius: var(--border-radius-btn);
    cursor: pointer;
    padding-block: 1rem;
    padding-inline: var(--size-3);
    text-align: center;
    text-decoration: none;
    width: fit-content;
  }

  .btn-primary {
    background-color: var(--clr-primary-900);
    color: var(--clr-primary-100);

    &:hover,
    &:active {
      background-color: var(--clr-secondary-900);
      color: var(--clr-secondary-100);
  }
  }

  .btn-primary-open {
    background-color: transparent;
    border: solid 1px var(--clr-primary-900);
    color: var(--clr-primary-900);
  }

  .btn-secondary {
    background-color: var(--clr-secondary-900);
    color: var(--clr-secondary-100);
  }

  .btn-secondary-open {
    background-color: transparent;
    border: solid 1px var(--clr-secondary-900);
    color: var(--clr-secondary-900);
  }

  .nav-btn {
    background-color: transparent;
    padding: 0;
    width: fit-content;
    grid-column: -3;
    margin-inline-start: auto;
  }

  .arrow-btn {
    background-color: transparent;
    padding: 0;
    width: fit-content;
  }

</style>
