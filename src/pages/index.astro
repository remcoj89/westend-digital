---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import IntroSection from '../sections/IntroSection.astro';
import UspSection from '../sections/UspSection.astro';
import HowWeWorkSection from '../sections/HowWeWorkSection.astro';
import ReviewSection from '../sections/ReviewSection.astro';
import FaqSection from '../sections/FaqSection.astro';
import CtaSection from '../sections/CtaSection.astro';
import FooterSection from '../sections/FooterSection.astro';
---

<Layout title="Westend Digital">
  <Header>
    <div>
      <h1>Winstgevende websites voor ondernemers met ambitie</h1>
      <span>Je bent klaar voor de volgende stap: van ambitie naar groei. Je wilt een website
        die doet wat ‘ie moet doen: leads genereren en je bedrijf laten groeien.
        Geen onnodige toeters en bellen, alleen resultaten. Zo simpel is het.</span>

    </div>
  </Header>
	<main>
    <IntroSection />
    <UspSection />
    <HowWeWorkSection client:load/>
    <ReviewSection />
    <FaqSection client:load />
    <CtaSection />
    <FooterSection />
	</main>
</Layout>
